# Database
DATABASE_URL=postgresql://localhost:5432/fretiko
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# API Configuration
API_URL=http://localhost:3000
NODE_ENV=development

# Flutterwave
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key

# Svix Webhook Management
SVIX_API_KEY=svix_test_your_api_key_here
SVIX_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Redis
REDIS_URL=redis://localhost:6379

# Agora (for video calls)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Resend Email Service (for partner authentication emails)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=partners@fretiko.com

# File Upload
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=fretiko-uploads

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Exchange Rate API Providers (Optional - free providers are used by default)
# EXCHANGERATE_API_KEY=your_exchangerate_api_key_here
# OPENEXCHANGE_API_KEY=your_openexchange_api_key_here

# LLM Configuration (Groq - free tier)
# Get your free API key at https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_groq_api_key_here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_MS=30000

# Optional: Tiered model configuration
# LLM_FAST_BASE_URL=https://api.groq.com/openai/v1
# LLM_FAST_MODEL=llama-3.1-8b-instant
# LLM_FAST_API_KEY=your_groq_api_key_here
# LLM_BALANCED_BASE_URL=https://api.groq.com/openai/v1
# LLM_BALANCED_MODEL=llama-3.3-70b-versatile
# LLM_BALANCED_API_KEY=your_groq_api_key_here
# LLM_STRONG_BASE_URL=https://api.together.xyz/v1
# LLM_STRONG_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
# LLM_STRONG_API_KEY=your_together_api_key_here

# Embedding Configuration (for RAG vector search)
# Hugging Face Inference API - free tier, no credit card needed
# Get your free token at https://huggingface.co/settings/tokens
EMBEDDING_BASE_URL=https://router.huggingface.co/hf-inference/models
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_API_KEY=your_huggingface_api_key_here
EMBEDDING_TIMEOUT_MS=15000

# Catalog indexing settings (used by scripts/index-catalog.ts)
INDEX_BATCH_SIZE=10
INDEX_DELAY_MS=500
